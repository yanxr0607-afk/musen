# ===== 混元大模型配置（复制为 .env 并填入你的密钥）=====
# 获取地址：https://console.cloud.tencent.com/hunyuan （或腾讯云 API 密钥）
# 仅服务端使用，不会下发到浏览器。

# 必填：混元 API Key（Bearer 鉴权，OpenAI 兼容端点）
HUNYUAN_API_KEY=

# 可选：模型名，默认 hunyuan-turbo（也可 hunyuan-pro / hunyuan-standard 等）
HUNYUAN_MODEL=hunyuan-turbo

# 可选：自定义端点（一般无需修改）
# HUNYUAN_URL=https://api.hunyuan.cloud.tencent.com/v1/chat/completions

# 可选：置为 0 可关闭 JSON 强制输出（极少数模型不支持时）
# HUNYUAN_JSON=1

# 可选：本地服务端口
# PORT=8787

# 必填（部署前务必修改！）：后台管理员密码
# 默认 opc-admin-dev 仅用于本地开发，公网必须改成强密码
ADMIN_PASS=opc-admin-dev

# 可选：数据持久化目录（挂载持久化卷后指向该卷路径，如 /data）
# DATA_DIR=./data
